@model RotaDoViajante.Models.Usuario

@{
    ViewData["Title"] = "Cadastro de Usuário";
}

<h2>Cadastro de Usuário</h2>

<div class="row">
    <div class="col-md-6">

        <form asp-controller="Usuario" asp-action="SalvarUsuario">

          
            <div class="mb-3">
                <label asp-for="NomeUsuario" class="control-label"></label>
                <input asp-for="NomeUsuario" class="form-control" />
                <span asp-validation-for="NomeUsuario" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TelefoneUsuario" class="control-label"></label>
                <input asp-for="TelefoneUsuario" class="form-control" />
                <span asp-validation-for="TelefoneUsuario" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="EmailUsuario" class="control-label"></label>
                <input asp-for="EmailUsuario" class="form-control" />
                <span asp-validation-for="EmailUsuario" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SenhaUsuario" class="control-label"></label>
                <input asp-for="SenhaUsuario" type="password" class="form-control" />
                <span asp-validation-for="SenhaUsuario" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">
                Salvar
            </button>

        </form>

    </div>
</div>