@model IEnumerable<RotaDoViajante.Models.Passeio>

@{
    ViewData["Title"] = "Lista de Passeios";
}

<div class="d-flex justify-content-between align-items-center mb-3">

    <h2>Lista de Passeios</h2>

    <a asp-controller="Passeio"
       asp-action="Cadastro"
       class="btn btn-info">

        Novo Cadastro

    </a>

</div>

<table class="table table-striped table-hover">

    <thead class="table-dark">

        <tr>

            <td>ID</td>
            <td>Nome</td>
            <td>Guia</td>
            <td>Ações</td>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.IdPasseio</td>
                <td>@item.NomePasseio</td>
                <td>@item.GuiaNavigation.NomeGuia</td>

                <td>

                    <a asp-action="Editar"
                       asp-route-id="@item.IdPasseio"
                       class="btn btn-primary">

                        Editar

                    </a>

                    <a asp-action="Detalhes"
                       asp-route-id="@item.IdPasseio"
                       class="btn btn-secondary">

                        Detalhes

                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>