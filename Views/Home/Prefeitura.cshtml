@{
    ViewData["Title"] = "Privacy Policy";
}

   

    <!-- Conteúdo -->
    <div class="main">

        <h2 class="title">Cadastro de Usuário</h2>

        <div class="card">
            <form>

                <div class="form-group">
                    <label>Nome</label>
                    <input type="text">
                </div>

                <div class="form-group">
                    <label>Email</label>
                    <input type="email">
                </div>

                <div class="form-group">
                    <label>Telefone</label>
                    <input type="number">
                </div>

                <div class="form-group">
                    <label>Senha</label>
                    <input type="password">
                </div>

                <div class="form-group">
                    <label>Tipo Usuário</label>
                    <select>
                        <option>Admin</option>
                        <option>Prefeitura</option>
                    </select>
                </div>

                <button>Salvar</button>

            </form>
     </<div>

     </div>